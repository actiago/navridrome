# Navidrome Environment Configuration
# Copy this file to .env and fill in your values

# Last.fm API credentials (optional - for scrobbling)
ND_LASTFM_APIKEY=your_lastfm_api_key_here
ND_LASTFM_SECRET=your_lastfm_secret_here

# Scan schedule (default: 1h)
# ND_SCANSCHEDULE=1h

# Log level (debug, info, warning, error)
# ND_LOGLEVEL=info

# Music folder path inside container
# ND_MUSICFOLDER=/music

# Data folder path inside container
# ND_DATAFOLDER=/data
